<Window x:Class="SpaSalon.Views.AppointmentEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запись клиента" 
        Height="600" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Text="Новая запись" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"
                   HorizontalAlignment="Center"/>

        <!-- Клиент -->
        <TextBlock Grid.Row="1" Text="Клиент:" Margin="0,5" FontWeight="SemiBold"/>
        <ComboBox x:Name="ClientComboBox" Grid.Row="2" Height="35" 
                  DisplayMemberPath="FullName" SelectedValuePath="Id"
                  Margin="0,5,0,15" IsEditable="True"
                  IsTextSearchEnabled="True" TextSearch.TextPath="FullName"/>

        <!-- Услуга -->
        <TextBlock Grid.Row="3" Text="Услуга:" Margin="0,5" FontWeight="SemiBold"/>
        <ComboBox x:Name="ServiceComboBox" Grid.Row="4" Height="35" 
                  DisplayMemberPath="Name" SelectedValuePath="Id"
                  Margin="0,5,0,5" SelectionChanged="ServiceComboBox_SelectionChanged"/>
        <TextBlock x:Name="ServiceDurationText" Grid.Row="5" FontSize="11" Foreground="#666" Margin="0,0,0,10"/>

        <!-- Мастер -->
        <TextBlock Grid.Row="6" Text="Мастер:" Margin="0,5" FontWeight="SemiBold"/>
        <ComboBox x:Name="MasterComboBox" Grid.Row="7" Height="35" 
                  DisplayMemberPath="FullName" SelectedValuePath="Id"
                  Margin="0,5,0,15"/>

        <!-- Дата и время -->
        <TextBlock Grid.Row="8" Text="Дата и время:" Margin="0,5" FontWeight="SemiBold"/>
        <StackPanel Grid.Row="9" Orientation="Horizontal" Margin="0,5,0,15">
            <DatePicker x:Name="DatePicker" Width="200" Height="35" 
                        SelectedDateChanged="DatePicker_SelectedDateChanged"/>
            <ComboBox x:Name="TimeComboBox" Width="120" Height="35" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Статус (только для редактирования) -->
        <TextBlock x:Name="StatusLabel" Grid.Row="10" Text="Статус:" Margin="0,5" FontWeight="SemiBold" Visibility="Collapsed"/>
        <ComboBox x:Name="StatusComboBox" Grid.Row="11" Height="35" Margin="0,5,0,15" Visibility="Collapsed">
            <ComboBoxItem Content="Новая" Tag="new"/>
            <ComboBoxItem Content="Подтверждена" Tag="confirmed"/>
            <ComboBoxItem Content="Выполнена" Tag="completed"/>
            <ComboBoxItem Content="Отменена" Tag="cancelled"/>
        </ComboBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="SaveButton" Content="Сохранить" Width="120" Height="40" 
                    Margin="10" Background="#27AE60" Foreground="White" FontSize="14"
                    Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="120" Height="40" 
                    Margin="10" Background="#95A5A6" Foreground="White" FontSize="14"
                    Click="CancelButton_Click"/>
        </StackPanel>

        <TextBlock x:Name="ErrorTextBlock" Grid.Row="13" Text="" Foreground="Red" 
                   FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>
    </Grid>
</Window>