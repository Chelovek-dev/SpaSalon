<Window x:Class="SpaSalon.Views.MaterialConsumptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учёт расхода материалов" 
        Height="480" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="📦 Учёт расхода материалов" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Информация о записи -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="12" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Запись:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBlock x:Name="AppointmentInfoText" Text="" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Выбор материала -->
        <TextBlock Grid.Row="2" Text="Выберите материал:" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <ComboBox x:Name="MaterialComboBox" Grid.Row="3" Height="38" 
                  DisplayMemberPath="Name" SelectedValuePath="Id"
                  Margin="0,0,0,15" SelectionChanged="MaterialComboBox_SelectionChanged"/>

        <!-- Количество -->
        <TextBlock Grid.Row="4" Text="Количество:" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBox x:Name="QuantityBox" Width="120" Height="38" Text="1" 
                     PreviewTextInput="NumberValidationTextBox"/>
            <TextBlock x:Name="UnitText" Text="" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <TextBlock x:Name="AvailableText" Text="" VerticalAlignment="Center" Margin="10,0,0,0" 
                       Foreground="#666" FontSize="11"/>
        </StackPanel>

        <!-- Расходные материалы по норме (показываем только если есть) -->
        <Expander x:Name="MaterialsExpander" Grid.Row="6" Header="📋 Расходные материалы по услуге" 
                  IsExpanded="False" Margin="0,0,0,15" Visibility="Collapsed">
            <DataGrid x:Name="ServiceMaterialsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      Height="120" Margin="0,10,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Материал" Binding="{Binding MaterialName}" Width="*"/>
                    <DataGridTextColumn Header="Норма" Binding="{Binding QuantityNeeded}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>

        <!-- Уже учтённые расходы (показываем только если есть) -->
        <Expander x:Name="ConsumedExpander" Grid.Row="7" Header="✅ Уже учтённые расходы" 
                  IsExpanded="False" Margin="0,0,0,15" Visibility="Collapsed">
            <ListBox x:Name="ConsumedMaterialsList" Height="100" Margin="0,10,0,0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <TextBlock Text="{Binding MaterialName}" Width="150"/>
                            <TextBlock Text="{Binding QuantityUsed}" Width="50" TextAlignment="Center"/>
                            <TextBlock Text="{Binding Unit}" Width="50"/>
                            <TextBlock Text="шт."/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Expander>

        <!-- Кнопки -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="AddButton" Content="➕ Добавить расход" Width="150" Height="40" 
                    Margin="10" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="AddButton_Click"/>
            <Button x:Name="CloseButton" Content="Закрыть" Width="120" Height="40" 
                    Margin="10" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="CloseButton_Click"/>
        </StackPanel>

        <!-- Сообщение об ошибке -->
        <TextBlock x:Name="ErrorTextBlock" Grid.Row="9" Text="" Foreground="#E74C3C" 
                   FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>
    </Grid>
</Window>