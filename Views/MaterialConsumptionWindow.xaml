<Window x:Class="SpaSalon.Views.MaterialConsumptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учёт расхода материалов" 
        Height="450" 
        Width="500"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Учёт расхода материалов" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Запись:" FontWeight="SemiBold" Margin="0,5"/>
        <TextBlock x:Name="AppointmentInfoText" Grid.Row="2" Text="" Margin="0,5,0,15" FontSize="14"/>

        <TextBlock Grid.Row="3" Text="Выберите материал:" FontWeight="SemiBold" Margin="0,5"/>
        <ComboBox x:Name="MaterialComboBox" Grid.Row="4" Height="35" 
                  DisplayMemberPath="Name" SelectedValuePath="Id"
                  Margin="0,5,0,15" SelectionChanged="MaterialComboBox_SelectionChanged"/>

        <TextBlock Grid.Row="5" Text="Количество:" FontWeight="SemiBold" Margin="0,5"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,5,0,15">
            <TextBox x:Name="QuantityBox" Width="150" Height="35" Text="1" PreviewTextInput="NumberValidationTextBox"/>
            <TextBlock x:Name="UnitText" Text="" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <TextBlock x:Name="AvailableText" Text="" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#666" FontSize="11"/>
        </StackPanel>

        <TextBlock Grid.Row="7" Text="Расходные материалы к этой услуге:" FontWeight="SemiBold" Margin="0,5"/>
        <DataGrid x:Name="ServiceMaterialsGrid" Grid.Row="8" AutoGenerateColumns="False" IsReadOnly="True"
                  MaxHeight="150" Margin="0,5,0,15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Материал" Binding="{Binding MaterialName}" Width="*"/>
                <DataGridTextColumn Header="Норма" Binding="{Binding QuantityNeeded}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="AddButton" Content="Добавить расход" Width="150" Height="40" 
                    Margin="10" Background="#27AE60" Foreground="White"
                    Click="AddButton_Click"/>
            <Button x:Name="CloseButton" Content="Закрыть" Width="120" Height="40" 
                    Margin="10" Background="#95A5A6" Foreground="White"
                    Click="CloseButton_Click"/>
        </StackPanel>

        <TextBlock x:Name="ErrorTextBlock" Grid.Row="10" Text="" Foreground="Red" 
                   FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>

        <ListBox x:Name="ConsumedMaterialsList" Grid.Row="11" Height="100" Margin="0,10,0,0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding MaterialName}" Width="150"/>
                        <TextBlock Text="{Binding QuantityUsed}" Width="50" TextAlignment="Center"/>
                        <TextBlock Text="шт."/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>