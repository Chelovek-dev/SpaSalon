<Window x:Class="SpaSalon.Views.PurchaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Закупки материалов" 
        Height="550" 
        Width="750"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Закупка материалов" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Форма добавления закупки -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Поставщик:" VerticalAlignment="Center"/>
                <ComboBox x:Name="SupplierComboBox" Grid.Column="1" Height="30" Margin="5"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Text="Материал:" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <ComboBox x:Name="MaterialComboBox" Grid.Column="3" Height="30" Margin="5"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Text="Кол-во:" Grid.Column="4" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <TextBox x:Name="QuantityBox" Grid.Column="5" Height="30" Margin="5" Text="1"/>

                <TextBlock Text="Цена:" Grid.Row="1" VerticalAlignment="Center" Margin="0,5,0,0"/>
                <TextBox x:Name="PriceBox" Grid.Row="1" Grid.Column="1" Height="30" Margin="5" Text="0"/>

                <TextBlock Text="Дата:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="10,5,0,0"/>
                <DatePicker x:Name="DatePicker" Grid.Row="1" Grid.Column="3" Height="30" Margin="5"/>

                <Button x:Name="AddPurchaseButton" Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2" 
                        Content="Оформить закупку" Width="150" Height="35" Margin="10,5,0,0"
                        Background="#27AE60" Foreground="White" Click="AddPurchaseButton_Click"
                        HorizontalAlignment="Left"/>
            </Grid>
        </Border>

        <!-- Таблица закупок -->
        <DataGrid x:Name="PurchasesDataGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding DateString}" Width="100"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding SupplierName}" Width="150"/>
                <DataGridTextColumn Header="Материал" Binding="{Binding MaterialName}" Width="150"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Цена за ед." Binding="{Binding PriceString}" Width="100"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPriceString}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="RefreshButton" Content="Обновить" Width="120" Height="35" 
                    Background="#3498DB" Foreground="White" Click="RefreshButton_Click"/>
            <Button x:Name="CloseButton" Content="Закрыть" Width="120" Height="35" 
                    Margin="10,0" Background="#95A5A6" Foreground="White" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>