<Window x:Class="SpaSalon.Views.SupplierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Поставщики" 
        Height="500" 
        Width="700"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Управление поставщиками" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Форма добавления/редактирования -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Наименование:" VerticalAlignment="Center"/>
                <TextBox x:Name="NameBox" Grid.Column="1" Height="30" Margin="5" Padding="5"/>
                <TextBlock Text="Телефон:" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <TextBox x:Name="PhoneBox" Grid.Column="3" Height="30" Margin="5" Padding="5"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="10,0,0,0">
                    <Button x:Name="AddSupplierButton" Content="Добавить" Width="80" Height="30" 
                            Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="AddSupplierButton_Click"/>
                    <Button x:Name="UpdateSupplierButton" Content="Обновить" Width="80" Height="30" 
                            Margin="5,0" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="UpdateSupplierButton_Click" Visibility="Collapsed"/>
                    <Button x:Name="CancelEditButton" Content="Отмена" Width="80" Height="30" 
                            Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="CancelEditButton_Click" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица поставщиков -->
        <DataGrid x:Name="SuppliersDataGrid" Grid.Row="2" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow"
                  SelectionChanged="SuppliersDataGrid_SelectionChanged"
                  AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                <DataGridTemplateColumn Header="Действия" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Удалить" 
                                    Style="{StaticResource DangerButton}"
                                    Click="DeleteSupplier_Click"
                                    Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="RefreshButton" Content="Обновить" Width="120" Height="35" 
                    Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="RefreshButton_Click"/>
            <Button x:Name="CloseButton" Content="Закрыть" Width="120" Height="35" 
                    Margin="10,0" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>