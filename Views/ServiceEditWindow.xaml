<Window x:Class="SpaSalon.Views.ServiceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Услуга" 
        Height="600" 
        Width="550"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Text="Добавление услуги" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Наименование:" Margin="0,5"/>
        <TextBox x:Name="NameBox" Grid.Row="2" Height="35" Margin="0,5,0,15"/>

        <TextBlock Grid.Row="3" Text="Стоимость (₽):" Margin="0,5"/>
        <TextBox x:Name="CostBox" Grid.Row="4" Height="35" Margin="0,5,0,15"/>

        <TextBlock Grid.Row="5" Text="Длительность (мин):" Margin="0,5"/>
        <TextBox x:Name="DurationBox" Grid.Row="6" Height="35" Margin="0,5,0,25"/>

        <!-- Расходные материалы -->
        <Expander Grid.Row="7" Header="Расходные материалы" IsExpanded="False" Margin="0,5">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5">
                    <ComboBox x:Name="MaterialComboBox" Width="200" Height="30" 
                              DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    <TextBox x:Name="MaterialQuantityBox" Width="80" Height="30" Margin="10,0" Text="1"/>
                    <Button x:Name="AddMaterialButton" Content="Добавить" Width="80" Height="30" 
                            Background="#3498DB" Foreground="White" Click="AddMaterialButton_Click"/>
                </StackPanel>

                <DataGrid x:Name="ServiceMaterialsGrid" Grid.Row="1" AutoGenerateColumns="False" 
                          IsReadOnly="True" Margin="0,10,0,0" Height="150">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Материал" Binding="{Binding MaterialName}" Width="*"/>
                        <DataGridTextColumn Header="Количество" Binding="{Binding QuantityNeeded}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Expander>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="SaveButton" Content="Сохранить" Width="100" Height="35" 
                    Margin="5" Background="#27AE60" Foreground="White"
                    Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="100" Height="35" 
                    Margin="5" Background="#95A5A6" Foreground="White"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>