<Window x:Class="SpaSalon.Views.RevenueReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчёт по выручке мастеров" 
        Height="550" 
        Width="900"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="HeaderText">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#666"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📊 Отчёт по выручке мастеров" FontSize="22" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Панель фильтров -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Период отчёта" FontWeight="Bold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <DatePicker x:Name="StartDatePicker" Width="150" Height="30"/>
                    <TextBlock Text=" — " VerticalAlignment="Center" Margin="10,0"/>
                    <DatePicker x:Name="EndDatePicker" Width="150" Height="30"/>
                    <Button x:Name="GenerateReportButton" Content="Сформировать" Width="120" Height="30" 
                            Margin="20,0,0,0" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="GenerateReportButton_Click"/>
                    <Button x:Name="ExportButton" Content="Экспорт в Excel" Width="120" Height="30" 
                            Margin="10,0,0,0" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="ExportButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Таблица выручки по мастерам -->
        <DataGrid x:Name="RevenueDataGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Мастер" Binding="{Binding MasterName}" Width="200" FontWeight="Bold"/>
                <DataGridTextColumn Header="Кол-во услуг" Binding="{Binding AppointmentsCount}" Width="120"/>
                <DataGridTextColumn Header="Выручка" Binding="{Binding RevenueDisplay}" Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#27AE60"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Доля от общей" Binding="{Binding SharePercent}" Width="120"/>
                <DataGridTextColumn Header="Средний чек" Binding="{Binding AverageCheck}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель итогов -->
        <Border Grid.Row="3" Background="#2C3E50" Padding="15" Margin="0,10,0,0" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Общая выручка" FontSize="12" Foreground="#BDC3C7"/>
                    <TextBlock x:Name="TotalRevenueText" Text="0 ₽" FontSize="24" FontWeight="Bold" Foreground="#2ECC71"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Всего услуг" FontSize="12" Foreground="#BDC3C7"/>
                    <TextBlock x:Name="TotalAppointmentsText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#3498DB"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Средний чек" FontSize="12" Foreground="#BDC3C7"/>
                    <TextBlock x:Name="AverageCheckText" Text="0 ₽" FontSize="24" FontWeight="Bold" Foreground="#F39C12"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>