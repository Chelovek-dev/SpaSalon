<Window x:Class="SpaSalon.Views.MasterScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Календарь занятости мастеров" 
        Height="600" 
        Width="1000"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📅 Календарь занятости мастеров" FontSize="22" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <!-- Панель управления -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="PrevWeekButton" Content="◀ Предыдущая неделя" Width="150" Height="35" 
                        Margin="5" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="PrevWeekButton_Click"/>
                <DatePicker x:Name="CurrentDatePicker" Width="130" Height="35" 
                            SelectedDateChanged="CurrentDatePicker_SelectedDateChanged"/>
                <Button x:Name="NextWeekButton" Content="Следующая неделя ▶" Width="150" Height="35" 
                        Margin="5" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="NextWeekButton_Click"/>
                <Button x:Name="TodayButton" Content="Сегодня" Width="100" Height="35" 
                        Margin="5" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="TodayButton_Click"/>
                <ComboBox x:Name="MasterFilterComboBox" Width="200" Height="35" Margin="20,0,0,0"
                          DisplayMemberPath="FullName" SelectedValuePath="Id"
                          SelectionChanged="MasterFilterComboBox_SelectionChanged"/>
            </StackPanel>
        </Border>

        <!-- Календарь -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ScheduleItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Время -->
                                <Border Grid.Column="0" Background="#2C3E50" CornerRadius="5" Margin="2">
                                    <TextBlock Text="{Binding TimeSlot}" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                                </Border>

                                <!-- Занятость мастеров -->
                                <WrapPanel Grid.Column="1" Margin="5,0">
                                    <ItemsControl ItemsSource="{Binding Appointments}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding Color}" CornerRadius="5" 
                                                        Margin="3" Padding="8,3" Cursor="Hand"
                                                        ToolTip="{Binding Tooltip}">
                                                    <TextBlock Text="{Binding DisplayText}" Foreground="White" FontSize="11"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Легенда -->
        <Border Grid.Row="3" Background="#F9F9F9" Padding="10" Margin="0,10,0,0" CornerRadius="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Легенда:" FontWeight="Bold" Margin="0,0,10,0"/>
                <Border Background="#FF9800" Width="20" Height="20" CornerRadius="3" Margin="0,0,5,0"/>
                <TextBlock Text="Новая запись" Margin="0,0,15,0"/>
                <Border Background="#4CAF50" Width="20" Height="20" CornerRadius="3" Margin="0,0,5,0"/>
                <TextBlock Text="Подтверждена" Margin="0,0,15,0"/>
                <Border Background="#2196F3" Width="20" Height="20" CornerRadius="3" Margin="0,0,5,0"/>
                <TextBlock Text="Выполнена" Margin="0,0,15,0"/>
                <Border Background="#F44336" Width="20" Height="20" CornerRadius="3" Margin="0,0,5,0"/>
                <TextBlock Text="Отменена" Margin="0,0,15,0"/>
                <Border Background="#E0E0E0" Width="20" Height="20" CornerRadius="3" Margin="0,0,5,0"/>
                <TextBlock Text="Свободно" Margin="0,0,15,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>