<Window x:Class="SpaSalon.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - СПА Салон" 
        Height="600" 
        Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#FF6B6B">
            <StackPanel VerticalAlignment="Center" Margin="30,0">
                <TextBlock Text="СПА Салон" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Foreground="White"/>
                <TextBlock Text="Система управления салоном" 
                           FontSize="16" 
                           Foreground="#FFE0E0E0"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Форма входа -->
        <Border Grid.Row="1" Background="White" Padding="30">
            <StackPanel>
                <TextBlock Text="Вход в систему" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#333"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Телефон" 
                           FontSize="14" 
                           Foreground="#666"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="LoginTextBox" 
                         Height="40"
                         FontSize="14"
                         Margin="0,0,0,20"
                         Padding="10,0"/>

                <TextBlock Text="Пароль" 
                           FontSize="14" 
                           Foreground="#666"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" 
                             Height="40"
                             FontSize="14"
                             Margin="0,0,0,30"
                             Padding="10,0"/>

                <Button x:Name="LoginButton" 
                        Content="ВОЙТИ" 
                        Height="45"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#FF6B6B"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="LoginButton_Click"/>

                <TextBlock x:Name="ErrorTextBlock" 
                           Text="" 
                           Foreground="Red" 
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           Visibility="Visible"/>
            </StackPanel>
        </Border>

        <!-- Нижняя информационная панель -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="15">
            <TextBlock Text="@ 2024 СПА Салон. Все права защищены." 
                       FontSize="11" 
                       Foreground="#999"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"/>
        </Border>
    </Grid>
</Window>