<Window x:Class="SpaSalon.Views.ClientEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клиент" 
        Height="500" 
        Width="450"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText" Text="Добавление клиента" 
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <!-- ФИО -->
            <TextBlock Grid.Row="1" Text="ФИО:" Margin="0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="FullNameBox" Grid.Row="2" Height="38" Margin="0,5,0,15" FontSize="14"/>

            <!-- Телефон -->
            <TextBlock Grid.Row="3" Text="Телефон:" Margin="0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="PhoneBox" Grid.Row="4" Height="38" Margin="0,5,0,5" FontSize="14"
                     PreviewTextInput="PhoneBox_PreviewTextInput"/>

            <TextBlock Grid.Row="5" Text="Пример: +7 (999) 123-45-67" FontSize="10" Foreground="#888" Margin="0,0,0,15"/>

            <!-- Дата рождения -->
            <TextBlock Grid.Row="6" Text="Дата рождения (необязательно):" Margin="0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="BirthDateBox" Grid.Row="7" Height="38" Margin="0,5,0,5" FontSize="14"/>

            <TextBlock Grid.Row="8" Text="Пример: 15.05.1990" FontSize="10" Foreground="#888" Margin="0,0,0,25"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,20">
                <Button x:Name="SaveButton" Content="Сохранить" Width="100" Height="40" 
                        Margin="5,0" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"
                        FontSize="14" FontWeight="Bold"
                        Click="SaveButton_Click"/>
                <Button x:Name="CancelButton" Content="Отмена" Width="100" Height="40" 
                        Margin="5,0" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"
                        FontSize="14" FontWeight="Bold"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>