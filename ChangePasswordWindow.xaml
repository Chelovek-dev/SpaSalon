<Window x:Class="SpaSalon.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Смена пароля" 
        Height="500" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Смена пароля" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Foreground="#333"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Текущий пароль:" FontSize="14" Margin="0,5"/>
        <PasswordBox x:Name="CurrentPasswordBox" 
                     Grid.Row="2" 
                     Height="35" 
                     Margin="0,5,0,15"
                     FontSize="14"/>

        <TextBlock Grid.Row="3" Text="Новый пароль:" FontSize="14" Margin="0,5"/>
        <PasswordBox x:Name="NewPasswordBox" 
                     Grid.Row="4" 
                     Height="35" 
                     Margin="0,5,0,5"
                     FontSize="14"/>

        <TextBlock x:Name="PasswordStrengthText" 
                   Grid.Row="5" 
                   FontSize="11" 
                   Foreground="#666"
                   Margin="0,0,0,15"/>

        <TextBlock Grid.Row="6" Text="Подтверждение пароля:" FontSize="14" Margin="0,5"/>
        <PasswordBox x:Name="ConfirmPasswordBox" 
                     Grid.Row="7" 
                     Height="35" 
                     Margin="0,5,0,20"
                     FontSize="14"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="ChangeButton" 
                    Content="Изменить" 
                    Width="105" 
                    Height="38"
                    Background="#3498DB" 
                    Foreground="White"
                    Click="ChangeButton_Click" RenderTransformOrigin="0.5,0.5">
                <Button.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleX="2.039"/>
                        <RotateTransform/>
                        <TranslateTransform X="0.73"/>
                    </TransformGroup>
                </Button.RenderTransform>
            </Button>
            <Button x:Name="CancelButton" 
                    Content="Отмена" 
                    Width="100" 
                    Height="35"
                    Margin="5"
                    Background="#95A5A6" 
                    Foreground="White"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>