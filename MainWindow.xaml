<Window x:Class="SpaSalon.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="СПА Салон - Система управления" 
        Height="750" 
        Width="1300"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#ECF0F1">

    <Window.Resources>
        <Storyboard x:Key="ButtonHover">
            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                             To="1.02" Duration="0:0:0.08"/>
            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                             To="1.02" Duration="0:0:0.08"/>
        </Storyboard>
        <Storyboard x:Key="ButtonLeave">
            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" 
                             To="1" Duration="0:0:0.08"/>
            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" 
                             To="1" Duration="0:0:0.08"/>
        </Storyboard>

        <Style TargetType="Button" x:Key="SideNavButton">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BDC3C7"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#34495E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== ЛЕВАЯ БОКОВАЯ ПАНЕЛЬ ==================== -->
        <Border Grid.Column="0" Background="#2C3E50">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Логотип -->
                    <Border Grid.Row="0" Background="#1A252F" Padding="20,25">
                        <StackPanel>
                            <TextBlock Text="💆‍♀️" FontSize="40" HorizontalAlignment="Center"/>
                            <TextBlock Text="СПА Салон" FontSize="20" FontWeight="Bold" 
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Система управления" FontSize="12" Foreground="#BDC3C7" 
                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Информация о пользователе -->
                    <Border Grid.Row="1" Background="#34495E" Margin="15,20,15,15" Padding="15,12" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="👤" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="UserInfoText" Foreground="White" FontSize="12" 
                                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Разделитель -->
                    <Rectangle Grid.Row="2" Height="1" Fill="#34495E" Margin="15,5,15,10"/>

                    <!-- Основная навигация -->
                    <StackPanel Grid.Row="3" Margin="15,10">
                        <TextBlock Text="ОСНОВНОЕ" FontSize="10" Foreground="#7F8C8D" 
                                   Margin="15,0,0,10" FontWeight="Bold"/>
                        <Button x:Name="NavClientsButton" Content="👥 Клиенты" 
                                Style="{StaticResource SideNavButton}" Click="NavClientsButton_Click"/>
                        <Button x:Name="NavServicesButton" Content="💇 Услуги" 
                                Style="{StaticResource SideNavButton}" Click="NavServicesButton_Click"/>
                        <Button x:Name="NavAppointmentsButton" Content="📅 Записи" 
                                Style="{StaticResource SideNavButton}" Click="NavAppointmentsButton_Click"/>
                    </StackPanel>

                    <!-- Разделитель -->
                    <Rectangle Grid.Row="4" Height="1" Fill="#34495E" Margin="15,5,15,10"/>

                    <!-- Отчёты -->
                    <StackPanel Grid.Row="5" Margin="15,10">
                        <TextBlock Text="ОТЧЁТЫ" FontSize="10" Foreground="#7F8C8D" 
                                   Margin="15,0,0,10" FontWeight="Bold"/>
                        <Button x:Name="ReportsButton" Content="📊 Отчёты по записям" 
                                Style="{StaticResource SideNavButton}" Click="ReportsButton_Click"/>
                        <Button x:Name="RevenueReportButton" Content="💰 Выручка мастеров" 
                                Style="{StaticResource SideNavButton}" Click="RevenueReportButton_Click"/>
                        <Button x:Name="MaterialReportButton" Content="📦 Складские остатки" 
                                Style="{StaticResource SideNavButton}" Click="MaterialReportButton_Click"/>
                        <Button x:Name="ScheduleButton" Content="📅 График работы" 
                                Style="{StaticResource SideNavButton}" Click="ScheduleButton_Click"/>
                        <Button x:Name="JournalButton" Content="📋 Журнал действий" 
                                Style="{StaticResource SideNavButton}" Click="JournalButton_Click"/>
                    </StackPanel>

                    <!-- Разделитель -->
                    <Rectangle Grid.Row="6" Height="1" Fill="#34495E" Margin="15,5,15,10"/>

                    <!-- Администрирование -->
                    <StackPanel Grid.Row="7" Margin="15,10">
                        <TextBlock Text="АДМИНИСТРИРОВАНИЕ" FontSize="10" Foreground="#7F8C8D" 
                                   Margin="15,0,0,10" FontWeight="Bold"/>
                        <Button x:Name="SuppliersButton" Content="🏪 Поставщики" 
                                Style="{StaticResource SideNavButton}" Click="SuppliersButton_Click"/>
                        <Button x:Name="PurchasesButton" Content="📦 Закупки материалов" 
                                Style="{StaticResource SideNavButton}" Click="PurchasesButton_Click"/>
                    </StackPanel>

                    <!-- Разделитель -->
                    <Rectangle Grid.Row="8" Height="1" Fill="#34495E" Margin="15,5,15,10"/>

                    <!-- Нижняя панель с системными кнопками -->
                    <StackPanel Grid.Row="9" Margin="15,10,15,20">
                        <Button x:Name="ChangePasswordButton" Content="🔑 Сменить пароль" 
                                Style="{StaticResource SideNavButton}" Click="ChangePasswordButton_Click"/>
                        <Button x:Name="LogoutButton" Content="🚪 Выход из системы" 
                                Style="{StaticResource SideNavButton}" Foreground="#E74C3C" 
                                Click="LogoutButton_Click"/>

                        <TextBlock Text="© 2024 СПА Салон" FontSize="9" Foreground="#7F8C8D" 
                                   HorizontalAlignment="Center" Margin="0,25,0,0"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- ==================== ПРАВАЯ ОБЛАСТЬ - КОНТЕНТ ==================== -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="#ECF0F1">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <TextBlock x:Name="CurrentTabTitle" Grid.Row="0" Text="Клиенты" 
                           FontSize="24" FontWeight="Bold" Foreground="#2C3E50" 
                           Margin="0,0,0,15"/>

                <!-- Панель Клиенты -->
                <Grid x:Name="ClientsPanel" Grid.Row="1" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F8F9FA" Padding="12" Margin="0,0,0,12" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SearchTextBox" Height="36" FontSize="13" VerticalContentAlignment="Center"/>
                            <Button x:Name="SearchButton" Grid.Column="1" Content="🔍 Поиск" 
                                    Width="90" Height="36" Margin="12,0,0,0"
                                    Background="#3498DB" Foreground="White" BorderThickness="0"
                                    Cursor="Hand" Click="SearchButton_Click"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="AddClientButton" Content="➕ Добавить" 
                                Width="110" Height="35" Background="#27AE60" Foreground="White"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                                Click="AddClientButton_Click"/>
                        <Button x:Name="EditClientButton" Content="✏️ Редактировать" 
                                Width="110" Height="35" Background="#3498DB" Foreground="White"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                                Click="EditClientButton_Click"/>
                        <Button x:Name="DeleteClientButton" Content="🗑️ Удалить" 
                                Width="90" Height="35" Background="#E74C3C" Foreground="White"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                                Click="DeleteClientButton_Click"/>
                        <Button x:Name="RefreshClientsButton" Content="🔄 Обновить" 
                                Width="90" Height="35" Background="#3498DB" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="RefreshClientsButton_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="ClientsDataGrid" Grid.Row="2" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                            <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDateString}" Width="120"/>
                            <DataGridTextColumn Header="Возраст" Binding="{Binding Age}" Width="70"/>
                            <DataGridTextColumn Header="Дата регистрации" Binding="{Binding RegistrationDateString}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Панель Услуги -->
                <Grid x:Name="ServicesPanel" Grid.Row="1" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="AddServiceButton" Content="➕ Добавить услугу" 
                                Width="130" Height="35" Background="#27AE60" Foreground="White"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                                Click="AddServiceButton_Click"/>
                        <Button x:Name="RefreshServicesButton" Content="🔄 Обновить" 
                                Width="90" Height="35" Background="#3498DB" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="RefreshServicesButton_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="ServicesDataGrid" Grid.Row="1" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Наименование услуги" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Стоимость" Binding="{Binding CostString}" Width="120"/>
                            <DataGridTextColumn Header="Длительность" Binding="{Binding DurationString}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Панель Записи -->
                <Grid x:Name="AppointmentsPanel" Grid.Row="1" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F8F9FA" Padding="12" Margin="0,0,0,12" CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅 Фильтр по дате:" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="12"/>
                            <DatePicker x:Name="FilterDatePicker" Width="130" Height="32"/>
                            <Button x:Name="ShowAllAppointmentsButton" Content="📋 Все записи" 
                                    Width="100" Height="32" Margin="15,0,0,0"
                                    Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    Click="ShowAllAppointmentsButton_Click"/>
                        </StackPanel>
                    </Border>

                    <WrapPanel Grid.Row="1" Margin="0,0,0,12">
                        <Button x:Name="AddAppointmentButton" Content="➕ Добавить запись" 
                                Width="130" Height="35" Background="#27AE60" Foreground="White"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,8,8"
                                Click="AddAppointmentButton_Click"/>
                        <Button x:Name="EditAppointmentButton" Content="✏️ Редактировать" 
                                Width="120" Height="35" Background="#3498DB" Foreground="White"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,8,8"
                                Click="EditAppointmentButton_Click"/>
                        <Button x:Name="CancelAppointmentButton" Content="❌ Отменить" 
                                Width="110" Height="35" Background="#E67E22" Foreground="White"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,8,8"
                                Click="CancelAppointmentButton_Click"/>
                        <Button x:Name="ConfirmAppointmentButton" Content="✅ Подтвердить" 
                                Width="110" Height="35" Background="#27AE60" Foreground="White"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,8,8"
                                Click="ConfirmAppointmentButton_Click"/>
                        <Button x:Name="CompleteAppointmentButton" Content="✔️ Выполнена" 
                                Width="110" Height="35" Background="#1ABC9C" Foreground="White"
                                BorderThickness="0" Cursor="Hand" Margin="0,0,8,8"
                                Click="CompleteAppointmentButton_Click"/>
                        <Button x:Name="RefreshAppointmentsButton" Content="🔄 Обновить" 
                                Width="90" Height="35" Background="#3498DB" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="RefreshAppointmentsButton_Click"/>
                    </WrapPanel>

                    <DataGrid x:Name="AppointmentsDataGrid" Grid.Row="2" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding DateOnlyString}" Width="90"/>
                            <DataGridTextColumn Header="Время" Binding="{Binding TimeOnlyString}" Width="70"/>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="180"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding ClientPhone}" Width="110"/>
                            <DataGridTextColumn Header="Услуга" Binding="{Binding ServiceName}" Width="200"/>
                            <DataGridTextColumn Header="Мастер" Binding="{Binding MasterName}" Width="130"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="90"/>
                            <DataGridTextColumn Header="Стоимость" Binding="{Binding CostString}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>